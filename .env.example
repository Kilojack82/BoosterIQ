# Anthropic
ANTHROPIC_API_KEY=

# Supabase (new key naming — Publishable + Secret model)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Personal access token for the Supabase CLI — generate at
# https://supabase.com/dashboard/account/tokens. Used by `supabase link`
# and `supabase db push` to push migrations from this repo.
SUPABASE_ACCESS_TOKEN=

# Google Drive / Sheets (OAuth client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Square (sandbox during dev)
SQUARE_APPLICATION_ID=
SQUARE_APPLICATION_SECRET=
SQUARE_ENVIRONMENT=sandbox

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
